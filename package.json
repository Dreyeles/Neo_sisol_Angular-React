{
    "name": "neo-sisol-unificado",
    "version": "1.0.0",
    "description": "Script para ejecutar frontend y backend simultáneamente",
    "scripts": {
        "start:backend": "npm run dev --prefix \"c:\\Users\\User\\Desktop\\TAREAS\\CICLO_4\\Desarrollo de aplicaciones Backend\\SISOL\\neo_sisol_react2\\backend-central\"",
        "start:proxy": "node proxy.js",
        "open:opera": "start opera http://localhost:4200",
        "start": "concurrently \"npm run start:backend\" \"npm run start:proxy\" \"npm run open:opera\"",
        "dev:frontend": "cd frontend && npm start"
    },
    "dependencies": {
        "concurrently": "^8.2.2"
    },
    "devDependencies": {
        "express": "^5.2.1",
        "http-proxy-middleware": "^3.0.5"
    }
}